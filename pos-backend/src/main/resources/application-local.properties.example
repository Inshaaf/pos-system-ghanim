# Copy this file to application-local.properties and fill in your real values.
# application-local.properties is gitignored — never commit the real one.

DB_URL=jdbc:postgresql://localhost:5432/ghanim_pos
DB_USERNAME=postgres
DB_PASSWORD=your_db_password

JWT_SECRET=replace-with-a-long-random-string-at-least-64-chars

IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_account

MANAGER_PIN=1234

ECOMMERCE_SYNC_API_KEY=your_sync_api_key
